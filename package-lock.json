import type { AppData, Region } from '@/types';

export function buildSeedData(region: Region): AppData {
  return {
    profile: { name: '', familyName: '', phone: '', locale: region === 'israel' ? 'he' : 'en', region, maxVehicles: 5 } as AppData['profile'],
    vehicles: [],
    ledger: [],
    documents: [],
    demoMode: false,
    onboardingDone: false,
  };
}
